TELEGRAM_BOT_TOKEN=YOUR-TELEGRAM-BOT-TOKEN
#TELEGRAM_BOT_TOKEN is your bot token.
#Get it from messaging @BotFather at https://t.me/botfather

OLLAMA_MODEL=gemma3
#OLLAMA_MODEL is the model you want to use.
#Make sure you have the model downloaded for it to work. Check with `ollama ls`

KEEP_ALIVE=-1
# KEEP_ALIVE: How long the model stays in RAM after a request.
# Options: -1 (forever), 0 (immediate), or durations like "5m" or "1h".

CONTEXT_WINDOW=2048
# CONTEXT_WINDOW The maximum number of tokens the model can process in one go.

MAX_HISTORY=10
# MAX_HISTORY: How many messages (user + bot) to keep in memory for each chat.
